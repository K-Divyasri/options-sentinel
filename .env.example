# Copy this file to ".env" (same folder) and fill in ONE provider's key.
# NEVER commit your real .env — the .gitignore already excludes it.

# --- Gemini (recommended: free, no credit card, does chat + embeddings) ---
# Get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-key-here

# --- Groq (free, fast, but needs a local embedding model) ---
# Get one at https://console.groq.com/keys
GROQ_API_KEY=

# --- OpenAI (paid) ---
OPENAI_API_KEY=

# --- Reddit (optional: enables crowd-emotion from social posts) ---
# Create a "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=options-sentinel/0.1 by u/your_reddit_username
